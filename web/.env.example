# ─────────────────────────────────────────────
# Supabase (게시판 + 배너)
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ADMIN_PASSWORD=

# ─────────────────────────────────────────────
# 카카오 SDK (공유 기능)
# ─────────────────────────────────────────────
NEXT_PUBLIC_KAKAO_JS_KEY=

# ─────────────────────────────────────────────
# 광고 — 심사 모드 (전역 스위치)
# ─────────────────────────────────────────────
# 'true'면 모든 광고(AdSense+AdFit) 렌더 중단 — AdSense 심사 중 "made for ads" 인상 회피.
# 승인 후 'false' 또는 변수 삭제 → 즉시 광고 복원.
# ⚠️ Vercel은 env 변경 후 자동 재배포 안 함 — Deployments → Redeploy (Build Cache OFF) 필요.
NEXT_PUBLIC_AD_REVIEW_MODE=false

# ─────────────────────────────────────────────
# 광고 — AdSense (Google)
# ─────────────────────────────────────────────
# 심사 통과 후 'true'로 변경. SDK는 항상 로드 (심사 위해 필수).
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-6002059361162458

# AdSense 광고 단위 slot ID (AdSense dashboard → 광고 단위에서 발급)
# 광고 위치 매핑:
#   QUESTION     — /exam/{n}/{q}  문제 풀이 페이지 (정답 확인 후)
#   NOTE         — /notes/{id}    요약노트 본문 중간 (강의 영상 후)
#   NOTE_BOTTOM  — /notes/{id}    요약노트 NoteActions 직후 (관련 문제 풀기 후)
#   RESULT       — /exam/{n}/result  시험 결과 페이지 (점수 카드 아래)
#   LANDING      — / (한능검 랜딩) LinkedPreview ↔ LatestExamsBand 사이
NEXT_PUBLIC_AD_SLOT_QUESTION=
NEXT_PUBLIC_AD_SLOT_NOTE=
NEXT_PUBLIC_AD_SLOT_NOTE_BOTTOM=
NEXT_PUBLIC_AD_SLOT_RESULT=
NEXT_PUBLIC_AD_SLOT_LANDING=

# ─────────────────────────────────────────────
# 광고 — AdFit (카카오 애드핏)
# ─────────────────────────────────────────────
# 카카오 애드핏 통과 후 'true'로 변경 (https://adfit.kakao.com)
# Spec: docs/multi-exam-hub-strategy-v3.html §05 / monetization-alternatives.html
NEXT_PUBLIC_ADFIT_ENABLED=false

# AdFit 광고 단위 ID (애드핏 대시보드 → 매체관리 → 광고단위 추가에서 발급)
# 형식: DAN-xxxxxxxxxx
# - RECTANGLE: 300x250 (본문 중간 / 시험 결과)
# - BANNER: 320x100 (모바일 상단 / 게시판)
# - SIDE: 160x600 또는 300x600 (데스크톱 사이드바 — 모바일에서 미사용)
NEXT_PUBLIC_ADFIT_UNIT_RECTANGLE=
NEXT_PUBLIC_ADFIT_UNIT_BANNER=
NEXT_PUBLIC_ADFIT_UNIT_SIDE=
