{
  "id": "s2-02",
  "title": "️ 고려의 후삼국 통일 과정",
  "era": "고려",
  "eraLabel": "고려",
  "sectionId": "s2",
  "content": "<details>\n  <summary><strong>\u2694\ufe0f \ud6c4\uc0bc\uad6d\uc758 \uc131\ub9bd</strong></summary>\n  <div class=\"content\">\n    <table>\n      <thead>\n        <tr><th>\uc138\ub825</th><th>\uac74\uad6d\uc790</th><th>\uac74\uad6d</th><th>\ub3c4\uc74d</th><th>\ud2b9\uc9d5</th></tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td><strong><span class=\"keyword\">\ud6c4\ubc31\uc81c</span></strong></td>\n          <td><span class=\"keyword\">\uacac\ud6e4</span></td>\n          <td>900\ub144</td>\n          <td>\uc644\uc0b0\uc8fc(\uc804\uc8fc)</td>\n          <td>\u2022 \uad70\uc778 \ucd9c\uc2e0, \uac15\ub825\ud55c \uad70\uc0ac\ub825<br>\u2022 \ubc31\uc81c \uacc4\uc2b9 \uc758\uc2dd<br>\u2022 \ucda9\uccad\u00b7\uc804\ub77c\ub3c4 \uc7a5\uc545<br>\u2022 \uacf5\uc0b0\uc804\ud22c\uc5d0\uc11c \uc655\uac74 \ub300\ud30c (\uc2e0\uc22d\uac80 \uc804\uc0ac)</td>\n        </tr>\n        <tr>\n          <td><strong>\ud6c4\uace0\uad6c\ub824<br>(\ud0dc\ubd09)</strong></td>\n          <td><span class=\"keyword\">\uad81\uc608</span></td>\n          <td>901\ub144</td>\n          <td>\uc1a1\uc545\u2192\ucca0\uc6d0</td>\n          <td>\u2022 \uc2e0\ub77c \uc655\uc871 \ucd9c\uc2e0 (\uc124)\n<br>\u2022 \uad6d\ud638: \ud6c4\uace0\uad6c\ub824\u2192\ub9c8\uc9c4(904)\u2192<span class=\"keyword\">\ud0dc\ubd09</span>(911)<br>\u2022 \ubbf8\ub959\uc2e0\uc559 \uc790\uce6d, \ud3ed\uc815<br>\u2022 918\ub144 \ubd80\ud558\ub4e4\uc5d0\uac8c \ucd95\ucd9c</td>\n        </tr>\n        <tr>\n          <td><strong><span class=\"keyword\">\uace0\ub824</span></strong></td>\n          <td><span class=\"keyword\">\uc655\uac74</span></td>\n          <td>918\ub144</td>\n          <td>\uc1a1\uc545(\uac1c\uc131)</td>\n          <td>\u2022 \ud638\uc871 \uc5f0\ud569 \uc815\ucc45 (\ud63c\uc778, \uc0ac\uc131\ucc45\ubd09)<br>\u2022 \uce5c\uc2e0\ub77c \uc815\ucc45<br>\u2022 <span class=\"keyword\">\ubc1c\ud574 \uc720\ubbfc</span> \ud3ec\uc6a9<br>\u2022 \ud574\uc0c1 \uc138\ub825 \uae30\ubc18 (\uc1a1\uc545 \ud638\uc871)</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</details>\n\n<details>\n  <summary><strong>\ud83d\udde1\ufe0f \ud1b5\uc77c \uacfc\uc815 \uc5f0\ud45c</strong></summary>\n  <div class=\"content\">\n    <table>\n      <thead>\n        <tr><th>\uc5f0\ub3c4</th><th>\uc0ac\uac74</th><th>\ub0b4\uc6a9</th></tr>\n      </thead>\n      <tbody>\n        <tr><td>918</td><td>\uace0\ub824 \uac74\uad6d</td><td>\uc655\uac74\uc774 \uad81\uc608\ub97c \ucd95\ucd9c\ud558\uace0 \uace0\ub824 \uac74\uad6d</td></tr>\n        <tr><td>926</td><td>\ubc1c\ud574 \uba78\ub9dd</td><td>\uac70\ub780 \uce68\ub7b5 \u2192 <span class=\"keyword\">\ubc1c\ud574 \uc720\ubbfc</span> \ub300\uac70 \uace0\ub824\ub85c \ub9dd\uba85</td></tr>\n        <tr><td>927</td><td><span class=\"keyword\">\uacf5\uc0b0 \uc804\ud22c</span></td><td>\uacac\ud6e4\uc774 \uc2e0\ub77c \uc655\uacbd \uc2b5\uaca9 \u2192 <span class=\"keyword\">\uacbd\uc560\uc655</span> \uc0b4\ud574, \uc655\uac74 \ub300\ud328 (<span class=\"keyword\">\uc2e0\uc22d\uac80</span> \uc804\uc0ac)</td></tr>\n        <tr><td>930</td><td><span class=\"keyword\">\uace0\ucc3d \uc804\ud22c</span></td><td>\uc548\ub3d9\uc5d0\uc11c \uc655\uac74\uc774 \uacac\ud6e4\uc744 \ub300\ud30c \u2192 \uc804\uc138 \uc5ed\uc804</td></tr>\n        <tr><td>935</td><td>\uc2e0\ub77c \uadc0\ubd80</td><td><span class=\"keyword\">\uacbd\uc21c\uc655</span>\uc774 \uc790\uc9c4\ud558\uc5ec \uace0\ub824\uc5d0 \ud56d\ubcf5</td></tr>\n        <tr><td>935</td><td>\uacac\ud6e4 \ub9dd\uba85</td><td>\uacac\ud6e4\uc774 \uc544\ub4e4 <span class=\"keyword\">\uc2e0\uac80</span>\uc5d0\uac8c \ucd95\ucd9c\ub418\uc5b4 \uace0\ub824\ub85c \ub9dd\uba85</td></tr>\n        <tr><td>936</td><td><span class=\"keyword\">\uc77c\ub9ac\ucc9c \uc804\ud22c</span></td><td>\uc2e0\uac80\uc758 \ud6c4\ubc31\uc81c\uad70 \uaca9\ud30c \u2192 <span class=\"highlight\">\ud6c4\uc0bc\uad6d \ud1b5\uc77c \uc644\uc131</span></td></tr>\n      </tbody>\n    </table>\n  </div>\n</details>\n\n<details>\n  <summary><strong>\ud83d\udc51 \uc655\uac74\uc758 \ud1b5\uc77c \uc804\ub7b5</strong></summary>\n  <div class=\"content\">\n    <ul>\n      <li><strong>\ud638\uc871 \uc5f0\ud569 \uc815\ucc45:</strong> \ud63c\uc778 \uc815\ucc45(\uc815\ub7b5\uacb0\ud63c), \uc0ac\uc131 \uce21\ubd09(\uc655\uc528 \ud558\uc0ac) \u2192 \ud638\uc871 \ud3ec\uc12d</li>\n      <li><strong>\uce5c\uc2e0\ub77c \uc815\ucc45:</strong> \uc2e0\ub77c\uc5d0 \uc6b0\ud638\uc801 \ud0dc\ub3c4 \u2192 \uacbd\uc21c\uc655 \uc790\uc9c4 \uadc0\ubd80 \uc720\ub3c4</li>\n      <li><strong>\ubc1c\ud574 \uc720\ubbfc \ud3ec\uc6a9:</strong> \"\ubc1c\ud574\ub294 \uc6b0\ub9ac\uc758 \uce5c\ucc99 \ub098\ub77c\" \u2192 \uace0\uad6c\ub824 \uacc4\uc2b9 \uc758\uc2dd</li>\n      <li><strong>\ubd81\uc9c4 \uc815\ucc45:</strong> \uc11c\uacbd(\ud3c9\uc591) \uc911\uc2dc \u2192 \uace0\uad6c\ub824 \uc606 \ub545 \ud68c\ubcf5 \uc758\uc9c0</li>\n    </ul>\n    <div class=\"note\">\u26a1 \uc655\uac74\uc758 \ud1b5\uc77c\uc740 \ubb34\ub825 + \uc678\uad50 \ubcd1\ud589! \uacac\ud6e4\uacfc \ub2ec\ub9ac \ud638\uc871\u00b7\uc2e0\ub77c\u00b7\ubc1c\ud574\ub97c \ud3ec\uc6a9\ud558\ub294 \uc720\ud654\ucc45\uc774 \ud575\uc2ec</div>\n  </div>\n</details>\n\n<details>\n  <summary><strong>\ud83d\udccc \uc2dc\ud5d8 \ud575\uc2ec \ud0a4\uc6cc\ub4dc</strong></summary>\n  <div class=\"content\">\n    <table>\n      <thead><tr><th>\ud0a4\uc6cc\ub4dc</th><th>\u2192 \uc5f0\uacb0</th></tr></thead>\n      <tbody>\n        <tr><td>\uacac\ud6e4, \uc804\uc8fc, 900\ub144</td><td>\ud6c4\ubc31\uc81c \uac74\uad6d</td></tr>\n        <tr><td>\uad81\uc608, \ud0dc\ubd09, \ucca0\uc6d0</td><td>\ud6c4\uace0\uad6c\ub824 \u2192 \ud3ed\uc815\uc73c\ub85c \ucd95\ucd9c</td></tr>\n        <tr><td>\uc655\uac74, 918\ub144, \uc1a1\uc545</td><td>\uace0\ub824 \uac74\uad6d</td></tr>\n        <tr><td>\uacf5\uc0b0\uc804\ud22c (927)</td><td>\uc2e0\uc22d\uac80 \uc804\uc0ac, \uc655\uac74 \ub300\ud328</td></tr>\n        <tr><td>\uace0\ucc3d\uc804\ud22c (930)</td><td>\uc655\uac74 \uc2b9\ub9ac, \uc804\uc138 \uc5ed\uc804</td></tr>\n        <tr><td>\uacbd\uc21c\uc655 (935)</td><td>\uc2e0\ub77c \uc790\uc9c4 \uadc0\ubd80</td></tr>\n        <tr><td>\uc2e0\uac80, \uc77c\ub9ac\ucc9c\uc804\ud22c (936)</td><td>\ud6c4\ubc31\uc81c \uba78\ub9dd \u2192 \ud1b5\uc77c</td></tr>\n        <tr><td>\ud63c\uc778\uc815\ucc45, \uc0ac\uc131\ucc21\ubd09</td><td>\uc655\uac74\uc758 \ud638\uc871 \ud3ec\uc12d \uc804\ub7b5</td></tr>\n        <tr><td>\ubc1c\ud574 \uc720\ubbfc \ud3ec\uc6a9</td><td>\"\uce5c\ucc99 \ub098\ub77c\" \u2192 \uace0\uad6c\ub824 \uacc4\uc2b9</td></tr>\n      </tbody>\n    </table>\n  </div>\n</details>",
