# Server
PORT=3001

# Gemini AI (required for AI question/image generation)
GEMINI_API_KEY=

# Cloudflare R2 (required for image storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=korea-history-data
R2_PUBLIC_URL=

# Vercel Deploy Hook (for web deployment button)
VERCEL_DEPLOY_HOOK_URL=

# Instagram Graph API (for 카드뉴스 자동 발행)
# - INSTAGRAM_USER_ID: Instagram Business Account ID (숫자)
# - INSTAGRAM_ACCESS_TOKEN: Meta 앱의 장기 액세스 토큰 (instagram_content_publish, pages_show_list 권한)
# - GRAPH_VERSION: 선택 (기본 v21.0)
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_GRAPH_VERSION=v21.0
